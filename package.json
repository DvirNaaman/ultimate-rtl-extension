{
  "name": "ultimate-rtl",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension that flips chat UI of Claude, ChatGPT and Gemini to right-to-left.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', {recursive:true, force:true}))\""
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
